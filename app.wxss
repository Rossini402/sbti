/* SBTI 全局样式 — 绿色自然主题 */

page {
  --bg: #f6faf6;
  --panel: #ffffff;
  --text: #1e2a22;
  --muted: #6a786f;
  --line: #dbe8dd;
  --soft: #edf6ef;
  --accent: #6c8d71;
  --accent-strong: #4d6a53;
  --shadow: 0 32rpx 80rpx rgba(47, 73, 55, 0.08);
  --radius: 44rpx;

  margin: 0;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  background: #f6faf6;
  color: var(--text);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--panel);
  border: 2rpx solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

/* 主按钮 */
.btn-primary {
  background: var(--accent-strong);
  color: #fff;
  padding: 28rpx 40rpx;
  border-radius: 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(77, 106, 83, 0.18);
  font-weight: 700;
  font-size: 30rpx;
  border: none;
  line-height: 1;
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  background: #fff;
  color: var(--accent-strong);
  padding: 28rpx 40rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--line);
  font-weight: 700;
  font-size: 30rpx;
  line-height: 1;
}

.btn-secondary::after {
  border: none;
}

/* 按钮禁用态 */
.btn-disabled {
  opacity: 0.55;
}

/* 胶囊标签 */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  background: var(--soft);
  border: 2rpx solid var(--line);
  font-size: 24rpx;
  color: var(--accent-strong);
}
