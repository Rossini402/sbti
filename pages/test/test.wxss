.shell {
  max-width: 980rpx;
  margin: 0 auto;
  padding: 48rpx 32rpx 112rpx;
}

.test-wrap {
  padding: 44rpx;
}

/* 进度条 */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 36rpx;
  flex-wrap: wrap;
}

.progress {
  flex: 1;
  min-width: 300rpx;
  height: 20rpx;
  background: #edf3ee;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #97b59c, #5b7a62);
  border-radius: 999rpx;
  transition: width 0.22s ease;
}

.progress-text {
  color: var(--muted);
  font-size: 26rpx;
  white-space: nowrap;
}

/* 题目列表 */
.question-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.question {
  border: 2rpx solid var(--line);
  border-radius: 36rpx;
  padding: 36rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
}

.question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.meta-dim {
  color: var(--muted);
  font-size: 24rpx;
}

.question-title {
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text);
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 28rpx;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--line);
  background: #fff;
}

.option-selected {
  border-color: #bcd0c1;
  background: #f8fcf9;
}

/* 自定义 radio */
.option-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid var(--line);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.option-radio-checked {
  border-color: var(--accent-strong);
}

.option-radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--accent-strong);
}

.option-code {
  font-weight: 800;
  color: var(--accent-strong);
  min-width: 44rpx;
  font-size: 30rpx;
}

.option-label {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text);
  flex: 1;
}

/* 底部操作 */
.actions-bottom {
  margin-top: 36rpx;
  padding-top: 12rpx;
}

.hint {
  display: block;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.btn-group {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}
